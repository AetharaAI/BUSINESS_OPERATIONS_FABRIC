# VoiceOps API base URL (no trailing slash)
VOICEOPS_API_BASE_URL=https://voice.aetherpro.us
# Public portal base URL used for invite/reset links in admin responses
# Example: https://voice.syndicateai.co
PORTAL_PUBLIC_BASE_URL=

# Cookie security in production should stay true
PORTAL_COOKIE_SECURE=false

# Internal admin onboarding routes (server-side only)
VOICEOPS_PLATFORM_ADMIN_KEY=
PORTAL_INVITE_TOKEN_SECRET=

# First-login password reset endpoint path on VoiceOps
# Example: /api/v1/auth/change-password
VOICEOPS_PASSWORD_RESET_PATH=

# Billing scaffold
PORTAL_BILLING_PROVIDER=stripe
# Example: https://billing.your-provider.com/customer/{tenant_id}
PORTAL_BILLING_MANAGE_URL_TEMPLATE=

# Stripe webhook ingestion
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
